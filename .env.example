# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Max tokens for Claude response (default: 4096)
# CLAUDE_MAX_TOKENS=4096

# Optional: System prompt for Claude
# CLAUDE_SYSTEM_PROMPT="You are a helpful assistant."

# Optional: WeChat iLink base URL (default: https://ilinkai.weixin.qq.com)
# WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com

# Optional: Max concurrent users (default: 10)
# MAX_CONCURRENT_USERS=10

# Optional: Session idle timeout in hours (default: 24)
# SESSION_IDLE_TIMEOUT_HOURS=24
